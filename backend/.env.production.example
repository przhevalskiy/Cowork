# ===========================================
# Cowork Backend Production Environment Variables
# ===========================================
# Set these in your Render dashboard under Environment settings

# Supabase Database & Auth
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# Anthropic (primary provider)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
ANTHROPIC_MODEL=claude-sonnet-4-6

# Hive integration
HIVE_API_KEY=your-hive-api-key
HIVE_USER_ID=your-hive-user-id
HIVE_WORKSPACE_ID=your-hive-workspace-id
HIVE_UAT_PROJECT_ID=

# Mistral (optional — overload fallback)
MISTRAL_API_KEY=your-mistral-key
MISTRAL_MODEL=mistral-large-latest

# Email copies (optional — Resend)
RESEND_API_KEY=your-resend-key
EMAIL_CC_ADDRESS=team@example.com

# Application Configuration
# Set this to your Render frontend URL after deployment
CORS_ORIGINS=https://cowork-frontend.onrender.com
DEBUG=false
LOG_LEVEL=INFO
