# ===========================================
# Cowork Backend Environment Variables
# ===========================================
# Copy this file to .env and fill in your values

# Anthropic
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
ANTHROPIC_MODEL=claude-sonnet-4-6

# Hive
HIVE_API_KEY=your-hive-api-key
HIVE_USER_ID=your-hive-user-id
HIVE_WORKSPACE_ID=your-hive-workspace-id
# Set to true to route requests through the UAT project maps (test folders)
# instead of the production projects. Per service_type / impact_type routing
# still applies — see UAT_*_PROJECT_MAP in app/services/hive_service.py.
HIVE_UAT_MODE=false

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# Application
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
DEBUG=true
LOG_LEVEL=INFO
